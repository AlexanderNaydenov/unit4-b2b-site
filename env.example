# Optional: override Hygraph Content API (defaults to Unit4 project endpoint in code)
# NEXT_PUBLIC_HYGRAPH_ENDPOINT=https://api-eu-central-1-shared-euc1-02.hygraph.com/v2/cmn7eamxe01eb08w7iw79c0qe/master

# Optional: Hygraph Permanent Auth Token (only if the API is not public)
# HYGRAPH_API_TOKEN=

# Production site URL for metadata (Open Graph, canonical)
# NEXT_PUBLIC_SITE_URL=https://your-app.vercel.app

# Do not put Vercel Deploy Hook URLs in env files committed to git.
# Configure Hygraph webhooks in the Studio (see docs/hygraph-vercel-webhook.md).
