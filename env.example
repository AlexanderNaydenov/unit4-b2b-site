# Optional: override Hygraph Content API (defaults to Unit4 project endpoint in code)
# NEXT_PUBLIC_HYGRAPH_ENDPOINT=https://api-eu-central-1-shared-euc1-02.hygraph.com/v2/cmn7eamxe01eb08w7iw79c0qe/master

# Optional: Hygraph Permanent Auth Token (only if the API is not public)
# HYGRAPH_API_TOKEN=

# Live preview (Draft Mode + DRAFT-stage API)
# Permanent Auth Token with default stage DRAFT — used when Draft Mode is enabled (iframe preview)
# HYGRAPH_PREVIEW_TOKEN=

# Shared secret for GET /api/draft (Hygraph Preview widget “Enable draft mode” URL)
# Must match the secret in Studio Preview URL templates
# HYGRAPH_DRAFT_SECRET=

# Studio base URL for click-to-edit (no trailing slash). Use your project’s region if different.
# See: https://hygraph.com/docs/developer-guides/schema/click-to-edit
# NEXT_PUBLIC_HYGRAPH_STUDIO_URL=https://app.hygraph.com

# Production site URL for metadata (Open Graph, canonical)
# NEXT_PUBLIC_SITE_URL=https://your-app.vercel.app

# Required for POST /api/revalidate (Hygraph on-demand revalidation webhook)
# Generate a long random string; set the same value in Hygraph (header or query — see docs)
# REVALIDATION_SECRET=

# Do not put Vercel Deploy Hook URLs in env files committed to git.
# Optional full rebuilds: docs/hygraph-vercel-webhook.md
